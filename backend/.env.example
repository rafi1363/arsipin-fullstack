DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
JWT_SECRET="replace_with_a_long_random_secret"
PORT=5000
CORS_ORIGIN="http://localhost:3000"

# Future document file storage, S3-compatible.
# Recommended for Arsipin MVP: Cloudflare R2.
STORAGE_PROVIDER="r2"
S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="arsipin-documents"
S3_ACCESS_KEY_ID="replace_with_storage_access_key"
S3_SECRET_ACCESS_KEY="replace_with_storage_secret_key"
S3_PUBLIC_BASE_URL=""
